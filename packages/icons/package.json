{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "@tsm/icons",
  "version": "0.0.0",
  "type": "module",
  "types": "index.d.ts",
  "exports": {
    ".": "./index.d.ts",
    "./*": "./dist/*"
  },
  "scripts": {
    "postinstall": "npm run build",
    "prebuild": "rm -rf ./dist",
    "build": "mkdir -p ./dist && cp ../../node_modules/bootstrap-icons/icons/* ./dist/"
  },
  "files": [
    "index.d.ts",
    "dist"
  ],
  "devDependencies": {
    "bootstrap-icons": "^1.13.1"
  }
}
